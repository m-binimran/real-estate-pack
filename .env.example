# Copy to .env and fill in. NEVER commit .env. Keep real client data out of the repo entirely.
# These are for tools an agent might integrate; the secret-scan hook blocks hardcoded keys in files.

# CRM (e.g. Follow Up Boss, kvCORE, LionDesk) - server-side only
CRM_API_KEY=your-crm-api-key

# MLS / IDX feed
MLS_API_KEY=your-mls-or-idx-key

# Email / SMS (CAN-SPAM / TCPA compliant sending)
EMAIL_API_KEY=your-email-provider-key

# Market / property data provider
MARKET_DATA_API_KEY=your-data-provider-key
